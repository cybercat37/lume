println "SQL template placeholders ({param})"

let created = sql"""
create table users (id integer primary key, name text not null)
""".exec()
print match created {
  Ok(v) -> v
  Error(e) -> e
}

let inserted = sql"""
insert into users (id, name) values ({id}, {name})
""".exec(["id": "2", "name": "Bob"])
print match inserted {
  Ok(v) -> v
  Error(e) -> e
}

let scalar = sql"""
select name from users where id = {id}
""".one(["id": "2"])
print match scalar {
  Ok(v) -> v
  Error(e) -> e
}
