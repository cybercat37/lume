println "transaction { ... } minimal"

let created = db.exec("create table users (id integer primary key, name text not null)")
print match created {
  Ok(v) -> str(v)
  Error(e) -> e
}

transaction {
  let inserted = db.exec("insert into users (id, name) values (10, 'Mia')")
  print match inserted {
    Ok(v) -> str(v)
    Error(e) -> e
  }
}

let total = db.scalar("select count(*) from users")
print match total {
  Ok(v) -> v
  Error(e) -> e
}
